# ─────────────────────────────────────────────
#  ENV — Production (Neon Cloud)
# ─────────────────────────────────────────────
#  🔧 Copy this file to .env.production and fill in:
#    DATABASE_URL → from https://console.neon.tech → Project Dashboard → Connect
#    ARCJET_KEY   → from https://app.arcjet.com
#
#  ⚠️  .env.production is gitignored — never commit real secrets.
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Neon Cloud Database
DATABASE_URL=postgres://user:password@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Arcjet
ARCJET_KEY=
